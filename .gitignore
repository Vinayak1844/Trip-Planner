# Git ignore patterns for AI Trip Planner

# Environment
.env
.env.local
.env.*.local

# IDE
.idea/
.vscode/
*.iml
*.swp
*.swo

# OS
.DS_Store
Thumbs.db

# Java / Maven
backend/target/
backend/.mvn/wrapper/maven-wrapper.jar
*.class
*.jar
*.war
*.log

# Node / Frontend
frontend/node_modules/
frontend/dist/
frontend/.vite/
*.local

# Python / AI Service
ai-service/__pycache__/
ai-service/.pytest_cache/
ai-service/.venv/
ai-service/venv/
ai-service/*.egg-info/
ai-service/.mypy_cache/

# Docker
docker/data/

# Misc
*.tmp
*.bak
